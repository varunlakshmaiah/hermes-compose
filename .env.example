# ==========================================
# Hermes Agent & Gateway Configuration
# ==========================================
# Copy these variables into the "Environment" tab of your Dokploy Compose project.
# By filling these out, you completely bypass the interactive setup wizard!
# Do NOT commit your actual .env file to GitHub.

# Primary LLM Provider (Required - You only need ONE of these!)
# We recommend OpenRouter for access to Hermes and other models.
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# GROQ_API_KEY=gsk_your-groq-key-here

# Integration Tokens (Optional, depending on what gateways you want to use)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Advanced System Settings
HERMES_DASHBOARD=1
HERMES_ALLOW_ROOT_GATEWAY=1
HERMES_LOG_LEVEL=info
GATEWAY_ALLOW_ALL_USERS=true
